# SIPOS Production Environment Configuration
# Copy this file to .env.production and update with actual values

# Application
APP_NAME=SIPOS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://sipos.belumbang.id

# Trust proxies (load balancer / reverse proxy)
APP_TRUSTED_PROXIES=*

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sipos_production
DB_USERNAME=sipos_prod
DB_PASSWORD=CHANGE_THIS_PASSWORD

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_QUEUE=default

# Queue
QUEUE_CONNECTION=redis

# Session
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# Cache
CACHE_DRIVER=redis
CACHE_PREFIX=sipos

# Logging
LOG_CHANNEL=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
LOG_MAX_FILES=14

# Mail (Mailpit for production or SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@sipos.belumbang.id"
MAIL_FROM_NAME="${APP_NAME}"

# File Upload
MAX_UPLOAD_SIZE=2048
UPLOAD_PATH=lansia

# Posyandu Configuration
POSYANDU_NAME=Posyandu Desa Belumbang
PER_PAGE=15

# Security
# Generate these keys and store in secure vault
# SESSION_SECRET_KEY=
# API_SECRET_KEY=

# Optional: External Services
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_URL=

# Optional: WhatsApp Notification (for future)
# WA_API_URL=
# WA_API_KEY=

# Optional: Monitoring
# SENTRY_LARAVEL_DSN=
# TELESCOPE_ENABLED=false

# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoiMTEwOTZlZGY3MDIzNmVkN2ZhZWY2YWU5YTZjZmY3YzgiLCJ0IjoiOTc1ZjY1OTMtNjcwMC00OTcwLWI2YzAtMjcwMjBkZGRlZjIxIiwicyI6Ik16RTFOak00TXpZdE5EZ3pOQzAwTXpoa0xUa3dPV010WWpoaE9UazBZbUZpTUdZMyJ9
